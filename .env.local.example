# Notion API設定
# このファイルをコピーして .env.local を作成し、値を入力してください
# cp .env.local.example .env.local

# Notion APIキー (https://www.notion.so/my-integrations で取得)
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 各NotionページのID
# ページIDはNotionのURLから取得できます:
# https://www.notion.so/[ページタイトル]-[ページID]
# ハイフンなしの32文字、またはハイフンあり形式 (xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx) どちらでもOK

NOTION_COURSES_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PRICING_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TOKUSHOHO_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PRIVACY_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TERMS_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
